<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List view ─────────────────────────────────────────── -->
    <record id="bsi_dashboard_config_list_view" model="ir.ui.view">
        <field name="name">bsi.dashboard.config.list</field>
        <field name="model">bsi.dashboard.config</field>
        <field name="arch" type="xml">
            <list string="Dynamic Dashboard Configs">
                <field name="name"/>
                <field name="year"/>
                <field name="quarter"/>
                <field name="month"/>
                <field name="decimal"/>
            </list>
        </field>
    </record>

    <!-- ── Form view ─────────────────────────────────────────── -->
    <record id="bsi_dashboard_config_form_view" model="ir.ui.view">
        <field name="name">bsi.dashboard.config.form</field>
        <field name="model">bsi.dashboard.config</field>
        <field name="arch" type="xml">
            <form string="Dynamic Dashboard Config">
                <header>
                    <div class="bsi-header-bar">

                        <!-- Row 1: action buttons + filters -->
                        <div class="bsi-header-row1">
                            <button name="action_view_report"
                                    string="Print"
                                    type="object"
                                    class="btn btn-primary btn-sm bsi-hdr-btn"
                                    icon="fa-file-pdf-o"/>
                            <button name="%(moleac_dynamic_dashboard.action_bsi_dashboard_filter_template)d"
                                    string="Filter Template"
                                    type="action"
                                    class="btn btn-secondary btn-sm bsi-hdr-btn"
                                    icon="fa-bookmark-o"/>

                            <div class="bsi-hdr-sep"/>

                            <div class="bsi-header-filter-item">
                                <span class="bsi-header-filter-label">Show Section</span>
                                <field name="active_section" nolabel="1" class="bsi-header-select"/>
                            </div>
                            <div class="bsi-header-filter-item">
                                <span class="bsi-header-filter-label">Apply Template</span>
                                <field name="filter_template_id" nolabel="1"
                                       class="bsi-header-select"
                                       options="{'no_create': false}"
                                       placeholder="Select template…"/>
                                <button name="action_apply_template"
                                        string="Apply"
                                        type="object"
                                        class="btn btn-secondary btn-sm"
                                        icon="fa-check"
                                        invisible="not filter_template_id"/>
                            </div>
                        </div>

                        <!-- Row 2: Period Configuration -->
                        <div class="bsi-header-period">
                            <div class="bsi-header-period-title">Period Configuration</div>
                            <div class="bsi-header-period-body">

                                <!-- Yearly -->
                                <div class="bsi-hp-group">
                                    <div class="bsi-hp-group-label">Yearly Data</div>
                                    <div class="bsi-hp-fields">
                                        <div class="bsi-hp-field">
                                            <span class="bsi-hp-sublabel">Year</span>
                                            <field name="year_sel" nolabel="1" class="bsi-hp-sel"/>
                                        </div>
                                        <div class="bsi-hp-field">
                                            <span class="bsi-hp-sublabel">Prev Years</span>
                                            <field name="previous_year_number" nolabel="1" class="bsi-hp-num"/>
                                        </div>
                                    </div>
                                </div>

                                <!-- Quarterly -->
                                <div class="bsi-hp-group">
                                    <div class="bsi-hp-group-label">Quarterly Data</div>
                                    <div class="bsi-hp-fields">
                                        <div class="bsi-hp-field">
                                            <span class="bsi-hp-sublabel">Quarter</span>
                                            <field name="quarter" nolabel="1" class="bsi-hp-sel"/>
                                        </div>
                                        <div class="bsi-hp-field">
                                            <span class="bsi-hp-sublabel">Year</span>
                                            <field name="quarter_year_sel" nolabel="1" class="bsi-hp-sel"/>
                                        </div>
                                        <div class="bsi-hp-field">
                                            <span class="bsi-hp-sublabel">Prev Qtrs</span>
                                            <field name="previous_quarter_number" nolabel="1" class="bsi-hp-num"/>
                                        </div>
                                    </div>
                                </div>

                                <!-- Monthly -->
                                <div class="bsi-hp-group">
                                    <div class="bsi-hp-group-label">Monthly Data</div>
                                    <div class="bsi-hp-fields">
                                        <div class="bsi-hp-field">
                                            <span class="bsi-hp-sublabel">Month</span>
                                            <field name="month" nolabel="1" class="bsi-hp-sel"/>
                                        </div>
                                        <div class="bsi-hp-field">
                                            <span class="bsi-hp-sublabel">Year</span>
                                            <field name="month_year_sel" nolabel="1" class="bsi-hp-sel"/>
                                        </div>
                                        <div class="bsi-hp-field">
                                            <span class="bsi-hp-sublabel">Prev Yrs</span>
                                            <field name="previous_month_number" nolabel="1" class="bsi-hp-num"/>
                                        </div>
                                    </div>
                                </div>

                                <!-- Display -->
                                <div class="bsi-hp-group bsi-hp-group-display">
                                    <div class="bsi-hp-group-label">Display</div>
                                    <div class="bsi-hp-fields">
                                        <div class="bsi-hp-field">
                                            <span class="bsi-hp-sublabel">Decimal</span>
                                            <field name="decimal" nolabel="1" class="bsi-hp-num"/>
                                        </div>
                                        <div class="bsi-hp-field">
                                            <span class="bsi-hp-sublabel">Divide By</span>
                                            <field name="value" nolabel="1" class="bsi-hp-num"/>
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </div>

                    </div><!-- /bsi-header-bar -->
                </header>

                <sheet>
                    <separator string="Department Report"/>
                    <div class="bsi-preview-outer">
                        <field name="report_preview_html"
                               widget="html"
                               readonly="1"
                               nolabel="1"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Window action ─────────────────────────────────────── -->
    <record id="action_bsi_dashboard_config" model="ir.actions.act_window">
        <field name="name">Data Mapping Config</field>
        <field name="res_model">bsi.dashboard.config</field>
        <field name="view_mode">form</field>
    </record>

</odoo>
