<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── List view ─────────────────────────────────────────── -->
    <record id="bsi_dashboard_config_list_view" model="ir.ui.view">
        <field name="name">bsi.dashboard.config.list</field>
        <field name="model">bsi.dashboard.config</field>
        <field name="arch" type="xml">
            <list string="Dynamic Dashboard Configs">
                <field name="name"/>
                <field name="year"/>
                <field name="quarter"/>
                <field name="month"/>
                <field name="decimal"/>
            </list>
        </field>
    </record>

    <!-- ── Form view ─────────────────────────────────────────── -->
    <record id="bsi_dashboard_config_form_view" model="ir.ui.view">
        <field name="name">bsi.dashboard.config.form</field>
        <field name="model">bsi.dashboard.config</field>
        <field name="arch" type="xml">
            <form string="Dynamic Dashboard Config">
                <header>
                    <button name="action_view_report"
                            string="Print PDF"
                            type="object"
                            class="btn-primary"
                            icon="fa-file-pdf-o"/>
                    <button name="action_download_xlsx"
                            string="Download XLSX"
                            type="object"
                            class="btn-secondary"
                            icon="fa-file-excel-o"/>
                </header>
                <sheet>

                    <!-- ── Period Configuration ──────────────────── -->
                    <separator string="Period Configuration"/>
                    <div class="bsi-period-bar">

                        <!-- Yearly Data -->
                        <div class="bsi-period-group">
                            <div class="bsi-period-label">Yearly Data</div>
                            <div class="bsi-period-fields">
                                <div class="bsi-field-stack">
                                    <span class="bsi-field-sublabel">Year</span>
                                    <field name="year_sel" nolabel="1" class="bsi-sel-field"/>
                                </div>
                                <div class="bsi-field-stack">
                                    <span class="bsi-field-sublabel">Previous Years</span>
                                    <field name="previous_year_number" nolabel="1" class="bsi-num-field"/>
                                </div>
                            </div>
                        </div>

                        <!-- Quarterly Data + Current Year Quarterly -->
                        <div class="bsi-period-group">
                            <div class="bsi-period-label">Quarterly Data</div>
                            <div class="bsi-period-fields">
                                <div class="bsi-field-stack">
                                    <span class="bsi-field-sublabel">Quarter</span>
                                    <field name="quarter" nolabel="1" class="bsi-sel-field"/>
                                </div>
                                <div class="bsi-field-stack">
                                    <span class="bsi-field-sublabel">Year</span>
                                    <field name="quarter_year_sel" nolabel="1" class="bsi-sel-field"/>
                                </div>
                                <div class="bsi-field-stack">
                                    <span class="bsi-field-sublabel">Previous Qtrs</span>
                                    <field name="previous_quarter_number" nolabel="1" class="bsi-num-field"/>
                                </div>
                            </div>
                            <div class="bsi-period-hint">Year alone → all 4 quarters</div>
                        </div>

                        <!-- Monthly Report + As Of Month + Current Year's Months -->
                        <div class="bsi-period-group">
                            <div class="bsi-period-label">Monthly Data</div>
                            <div class="bsi-period-fields">
                                <div class="bsi-field-stack">
                                    <span class="bsi-field-sublabel">Month</span>
                                    <field name="month" nolabel="1" class="bsi-sel-field"/>
                                </div>
                                <div class="bsi-field-stack">
                                    <span class="bsi-field-sublabel">Year</span>
                                    <field name="month_year_sel" nolabel="1" class="bsi-sel-field"/>
                                </div>
                                <div class="bsi-field-stack">
                                    <span class="bsi-field-sublabel">Previous Yrs</span>
                                    <field name="previous_month_number" nolabel="1" class="bsi-num-field"/>
                                </div>
                            </div>
                            <div class="bsi-period-hint">Year alone → all 12 months</div>
                        </div>

                    </div>

                    <!-- ── Display options ───────────────────────── -->
                    <div class="bsi-options-bar">
                        <div class="bsi-opt-item">
                            <span class="bsi-opt-label">Decimal</span>
                            <field name="decimal" nolabel="1"/>
                        </div>
                        <div class="bsi-opt-item">
                            <field name="is_divide" nolabel="1"/>
                            <span class="bsi-opt-label">Divide by</span>
                            <field name="value" nolabel="1" invisible="not is_divide"/>
                        </div>
                    </div>

                    <!-- ── Department + Data preview ─────────────── -->
                    <separator string="Department Report"/>
                    <div class="bsi-preview-outer">
                        <field name="report_preview_html"
                               widget="html"
                               readonly="1"
                               nolabel="1"/>
                    </div>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Window action ─────────────────────────────────────── -->
    <record id="action_bsi_dashboard_config" model="ir.actions.act_window">
        <field name="name">Data Mapping Config</field>
        <field name="res_model">bsi.dashboard.config</field>
        <field name="view_mode">form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Dynamic Dashboard Configuration
            </p>
            <p>
                Set the periods (Year / Quarter / Month) above. The department
                hierarchy from <b>Accounting → Data Mapping Config → Data Mapping</b>
                is loaded automatically with clickable ▶ / ▼ arrows to expand or
                collapse each department group. Download as <b>PDF</b> or <b>XLSX</b>.
            </p>
        </field>
    </record>

</odoo>
